fin-o1-8b-think:
    endpoints:
        - api_base: http://localhost:8000/v1
          api_key: ${LOCAL_API_KEY}
    api_type: openai
    model: TheFinAI/Fin-o1-8B
    temperature: 0.6
    max_tokens: 25000
    seed: 42
    parallel: 1
    reasoning:
        effort: "medium"
        exclude: false
    sys_prompt: 'You are a helpful AI Assistant that provides well-reasoned and detailed responses. You first think about the reasoning process as an internal monologue and then provide the user with the answer.'
    prompt_suffix: "/think"


fin-o1-8b-nothink:
    endpoints:
        - api_base: http://localhost:8000/v1
          api_key: ${LOCAL_API_KEY}
    api_type: openai
    model: TheFinAI/Fin-o1-8B
    temperature: 0.6
    max_tokens: 25000
    seed: 42
    parallel: 1
    reasoning:
        effort: "low"
        exclude: true
    sys_prompt: 'You are a helpful AI assistant that provides only well-justified and detailed answers.\nDo not use internal monologue, chain-of-thought, or any kind of reasoning process in your response.\nDo not explain your answer or show your thought process.\nJust provide the final answer, with any necessary factual details, but without any reasoning steps.'
