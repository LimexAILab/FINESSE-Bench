# Copy this to .env and fill in your actual values
# cp .env.example .env

# OpenRouter API Key
# Get from: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-real-key-here

# Local Model API Key (for vllm/sglang servers)
# Usually sk-localtest for local development
LOCAL_API_KEY=sk-localtest
